<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>What Should I Eat?</title>

  <!-- Link CSS -->
  <link rel="stylesheet" href="style.css">

  <!-- Google Font -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
</head>
<body>

  <div class="container">
    <h1>🍽️ What Should I Eat?</h1>
    <p>Let us decide your next meal</p>

    <label>Your Budget</label>
    <div class="budget-inputs">
      <input type="number" id="minBudget" placeholder="Min ₱" min="0">
      <input type="number" id="maxBudget" placeholder="Max ₱" min="0">
    </div>

    <label>Mood</label>
    <select id="mood">
      <option value="comfort">Comfort Food</option>
      <option value="date">Date Food</option>
      <option value="quick">Quick Meal</option>
    </select>

    <button onclick="pickFood()">Pick My Food</button>

    <div id="result" class="loading">Loading food database...</div>
    <img id="foodImg" />

    <div class="toggle" onclick="toggleDarkMode()">Toggle Dark Mode 🌙</div>
    <div class="ads">Ad Space</div>
  </div>

  <script>
    let foods = [];

    // Google Sheets URL (replace YOUR_SHEET_ID)
    const SHEET_URL = "https://opensheet.elk.sh/1lvF1lf-2fY3mYvL_CYnA-vLy9VT5CV8lBnQI80XFL2o/Sheet1";

    // Fetch data from Google Sheets
    fetch(SHEET_URL)
      .then(res => res.json())
      .then(data => {
        console.log("Loaded data:", data); // Debug
        foods = data.map(item => ({
          name: item.Name,
          minBudget: Number(item.minBudget),
          maxBudget: Number(item.maxBudget),
          mood: item.Mood,
          image: item.Image
        }));
        document.getElementById("result").innerText = "Click the button to decide!";
      })
      .catch(err => {
        console.error("Error loading sheet:", err);
        document.getElementById("result").innerText = "Failed to load food database 😢";
      });

    function pickFood() {
      if (foods.length === 0) return;

      const minBudgetInput = Number(document.getElementById("minBudget").value) || 0;
      const maxBudgetInput = Number(document.getElementById("maxBudget").value) || Infinity;
      const mood = document.getElementById("mood").value;

      const filtered = foods.filter(food =>
        // Overlapping budget logic
        food.minBudget <= maxBudgetInput &&
        food.maxBudget >= minBudgetInput &&
        // Check multiple moods
        (food.mood || "").split(",").map(m => m.trim()).includes(mood)
      );

      if (filtered.length === 0) {
        document.getElementById("result").innerText = "No match 😢";
        document.getElementById("foodImg").style.display = "none";
        return;
      }

      document.getElementById("result").innerText = "Choosing your food... 🍽️";
      document.getElementById("foodImg").style.display = "none";

      setTimeout(() => {
        const random = filtered[Math.floor(Math.random() * filtered.length)];
        document.getElementById("result").innerText = "🍜 You should eat: " + random.name;

        if (random.image) {
          const img = document.getElementById("foodImg");
          img.src = random.image;
          img.style.display = "block";
        }
      }, 1500);
    }

    function toggleDarkMode() {
      document.body.classList.toggle("dark");
    }
  </script>
</body>
</html>
